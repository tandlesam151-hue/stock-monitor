# Copy this file to .env and fill in your actual credentials
# This file is NOT committed to version control for security

# Telegram Configuration
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Configuration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# Timezone (optional, defaults to Asia/Kolkata)
TIMEZONE=Asia/Kolkata

# PostgreSQL + TimescaleDB connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=stock_monitor
DB_USER=stockbot
DB_PASSWORD=your_db_password_here

# DB resilience (optional). Bound how long a scan waits on the database and how
# long the circuit breaker stays open after a failure, so a DB outage fails fast
# instead of hanging every scan.
DB_CONNECT_TIMEOUT=3
DB_POOL_TIMEOUT=3
DB_BREAKER_COOLDOWN=60

# Persistence toggles (true/false): write 5-min OHLCV bars and signal snapshots
PERSIST_OHLCV=true
PERSIST_SIGNALS=true

# Market-hours gating (true/false). Production-safe defaults are false, which
# limits scanning to MARKET_OPEN-MARKET_CLOSE on weekdays. Set ALLOW_ANYTIME=true
# to force scans at any time (useful for testing outside market hours).
ALLOW_ANYTIME=false
ALLOW_WEEKEND_RUN=false
